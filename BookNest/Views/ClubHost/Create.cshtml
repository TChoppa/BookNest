@model ClubHostRoom

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0 text-center"> Club Host Room</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Name (Creator)</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                </div>
                <div class="mb-3">
                    <label asp-for="Topic" class="form-label fw-semibold">Topic</label>
                    <input asp-for="Topic" class="form-control" placeholder="Enter discussion topic" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartTime" class="form-label fw-semibold">Start Time</label>
                        <input asp-for="StartTime" type="datetime-local" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EndTime" class="form-label fw-semibold">End Time</label>
                        <input asp-for="EndTime" type="datetime-local" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Location" class="form-label fw-semibold">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="Enter location" />
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle"></i> Create Room
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
