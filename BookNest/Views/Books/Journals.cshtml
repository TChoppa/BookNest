@{
    ViewBag.Title = "Journals";
    ViewBag.PageTitle = "Journals 📚";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        overflow-y: scroll;
    }

    html {
        overflow-y: scroll;
    }

    body {
        overflow-x: hidden;
    }

    /* ── Title Card ── */
    .academic-title-card {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 14px 20px;
        width: 90%;
        max-width: 420px;
        margin: 10px auto 20px;
        border-radius: 16px;
        background: #ffffff;
        border: 1.5px solid #dbeafe;
        box-shadow: 0 6px 15px rgba(79, 70, 229, 0.08);
    }

    /* ── Book Card ── */
    .book-closed {
        position: relative;
        width: 265px;
        min-width: 265px;
        max-width: 265px;
        height: 296px;
        margin: auto;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 12px 25px rgba(0,0,0,0.3);
    }

        .book-closed img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* ── Book Spine ── */
    .book-spine {
        position: absolute;
        left: 0;
        top: 0;
        width: 12px;
        height: 100%;
        background: linear-gradient(to right, #888, #ccc);
        z-index: 2;
    }

    /* ── QTY Badge ── */
    .qty-badge {
        position: absolute;
        top: 8px;
        left: 16px;
        background: rgba(0,0,0,0.75);
        color: #fff;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        z-index: 3;
    }

    /* ── Add Overlay ── */
    .add-overlay {
        position: absolute;
        bottom: 8px;
        right: 8px;
        z-index: 3;
        min-height: 36px;
    }

    .qty {
        cursor: default;
        user-select: none;
    }

    .add-overlay .add-btn {
        background: rgba(0,0,0,0.4);
        border: 1px solid #fff;
        color: #fff;
        font-weight: 600;
        border-radius: 10px;
        padding: 4px 14px;
    }

        .add-overlay .add-btn:hover {
            background: rgba(0,0,0,0.6);
        }

        .add-overlay .add-btn[disabled] {
            background: rgba(0,0,0,0.15);
            color: rgba(255,255,255,0.6);
            border-color: rgba(255,255,255,0.2);
            cursor: not-allowed;
        }

    /* ── Qty Controls ── */
    .qty-controls {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(0,0,0,0.4);
        border-radius: 10px;
        padding: 4px 6px;
    }

        .qty-controls .btn {
            background: transparent !important;
            border: none;
            color: #fff;
            font-weight: bold;
        }

            .qty-controls .btn:hover {
                background: rgba(255,255,255,0.15) !important;
            }

        .qty-controls .qty {
            color: #fff;
            font-weight: 600;
            min-width: 20px;
            text-align: center;
        }

    /* ── Loading State ── */
    .loading-state {
        text-align: center;
        padding: 60px 20px;
        color: #8b7ec8;
        font-size: 14px;
    }

        .loading-state i {
            font-size: 36px;
            display: block;
            margin-bottom: 12px;
            opacity: 0.5;
        }

    /* ── Empty State ── */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #a89fd8;
        font-size: 14px;
    }

        .empty-state i {
            font-size: 36px;
            display: block;
            margin-bottom: 12px;
            opacity: 0.4;
        }

    /* ── Cart Button ── */
    .view-orders-btn {
        position: fixed;
        bottom: 25px;
        right: 25px;
        z-index: 9999;
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 12px 22px;
        font-weight: 600;
        box-shadow: 0 10px 25px rgba(79,70,229,0.4);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .view-orders-btn:hover {
            background: linear-gradient(135deg, #4338ca, #4f46e5);
            color: #fff;
        }

    .cart-badge {
        position: absolute;
        top: -11px;
        right: -6px;
        background: red;
        color: white;
        border-radius: 50%;
        min-width: 24px;
        height: 24px;
        line-height: 23px;
        text-align: center;
        font-size: 15px;
        font-weight: bold;
    }

    .sidebar {
        width: 240px;
        min-width: 240px;
        max-width: 240px;
    }
</style>

<!-- Title Card -->
<div class="card academic-title-card">
    <h4 class="mb-0 fw-bold text-center"> JOURNALS</h4>
</div>

<!-- Books Grid -->
<div class="container-fluid">
    <div class="row g-4" id="journalRow">
        <!-- Loading state -->
        <div class="col-12 loading-state" id="loadingState">
            <i class="bi bi-arrow-repeat spin"></i>
            Loading journals...
        </div>
    </div>
</div>

<!-- Cart Button -->
<a id="cartView" href="/CartControllercs/ViewCart" class="btn view-orders-btn" style="display:none;">
    <i class="bi bi-cart-check"></i> View Cart
    <span id="cartBadge" class="cart-badge">0</span>
</a>

@section Scripts {
    <script>
        let cart = {};

        $(function () {

            // ── Load journals on page load ──
            loadJournals();

            function loadJournals() {
                $.ajax({
                    url: '/Books/GetYearBooks',
                    type: 'POST',
                    data: { branch: 'Journals', year: 'All' }, // ✅ category = Journals, no year filter
                    success: function (response) {
                        var books = response;
                        let html = '';

                        if (books.length === 0) {
                            html = '<div class="col-12">' +
                                   '<div class="empty-state">' +
                                   '<i class="bi bi-journal-x"></i>' +
                                   'No journals available at the moment.' +
                                   '</div></div>';
                            $('#journalRow').html(html);
                            return;
                        }

                        $.each(books, function (_, book) {

                            // Sync JS cart with backend cart
                            if (book.cartQty > 0) {
                                cart[book.title] = book.cartQty;
                            }

                            html += `
                            <div class="col-12 col-sm-6 col-lg-3 d-flex justify-content-center">
                                <div class="book-closed">
                                    <div class="book-spine"></div>
                                    <span class="qty-badge">QTY: ${book.availableQuantity}</span>
                                    <img src="${book.imageUrl}" alt="${book.title}">
                                    <div class="add-overlay cart-controls"
                                         data-id="${book.bookId}"
                                         data-title="${book.title}"
                                         data-qty="${book.cartQty}"
                                         data-imageurl="${book.imageUrl}"
                                         data-year="${book.year}"
                                         data-available="${book.availableQuantity}">

                                        <button class="btn add-btn ${book.cartQty > 0 ? 'd-none' : ''}"
                                                ${book.availableQuantity <= 0 ? 'disabled' : ''}>
                                            ${book.availableQuantity <= 0 ? 'OUT' : 'ADD'}
                                        </button>

                                        <div class="qty-controls ${book.cartQty > 0 ? '' : 'd-none'}">
                                            <button class="btn minus">−</button>
                                            <span class="qty">${book.cartQty > 0 ? book.cartQty : 1}</span>
                                            <button class="btn plus">+</button>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        });

                        $('#journalRow').html(html);

                        // Apply availability rules after DOM insertion
                        $('.cart-controls').each(function () {
                            const container = $(this);
                            const avail = Number(container.data('available'));
                            const qty   = Number(container.find('.qty').text()) || 0;

                            if (avail <= 0 && qty === 0) {
                                container.find('.add-btn').prop('disabled', true).text('OUT');
                            }

                            if (qty >= avail) {
                                container.find('.plus').prop('disabled', true);
                            } else {
                                container.find('.plus').prop('disabled', false);
                            }
                        });

                        updateCartUIFromServer();
                        updateQtyControlsBasedOnRole();
                    },
                    error: function () {
                        $('#journalRow').html(
                            '<div class="col-12">' +
                            '<div class="empty-state">' +
                            '<i class="bi bi-exclamation-circle"></i>' +
                            'Failed to load journals. Please try again.' +
                            '</div></div>'
                        );
                    }
                });
            }

            // ── Update cart badge from server ──
            function updateCartUIFromServer() {
                $.ajax({
                    url: '/CartControllercs/GetCartCount',
                    type: 'GET',
                    success: function (count) {
                        if (count > 0) {
                            $('#cartView').show();
                            $('#cartBadge').text(count).removeClass('d-none');
                        } else {
                            $('#cartView').hide();
                            $('#cartBadge').addClass('d-none');
                        }
                    }
                });
            }

            // ── Update qty controls based on role ──
            function updateQtyControlsBasedOnRole() {
                $.ajax({
                    url: '/Home/GetUserRole',
                    type: 'GET',
                    success: function (role) {
                        if (role === 'Student') {
                            $('.cart-controls').each(function () {
                                let container = $(this);
                                let qty = Number(container.find('.qty').text());
                                container.find('.plus').prop('disabled', qty >= 1);
                            });
                        } else if (role === 'Faculty') {
                            $('.cart-controls').each(function () {
                                let container = $(this);
                                let qty = Number(container.find('.qty').text());
                                container.find('.plus').prop('disabled', qty >= 5);
                            });
                        }
                    }
                });
            }

            // ── ADD button click ──
            $(document).on('click', '.add-btn', function () {
                if ($(this).prop('disabled')) return;

                const container = $(this).closest('.cart-controls');
                const title     = container.data('title');

                cart[title] = 1;
                container.find('.qty').text(1);

                $(this).addClass('d-none');
                container.find('.qty-controls').removeClass('d-none');

                const avail = Number(container.data('available'));
                if (1 >= avail) {
                    container.find('.plus').prop('disabled', true);
                }

                var itemDetails = {
                    BookId            : container.data('id'),
                    Title             : container.data('title'),
                    ImageUrl          : container.data('imageurl'),
                    AvailableQuantity : container.data('qty'),
                    Year              : container.data('year'),
                    Username          : "@Context.Session.GetString("UserName")"
                };

                $.ajax({
                    url         : '/CartControllercs/AddToCart',
                    type        : 'POST',
                    data        : JSON.stringify(itemDetails),
                    contentType : 'application/json',
                    success     : function () {
                        updateQtyControlsBasedOnRole();
                        updateCartUIFromServer();
                    }
                });
            });

            // ── PLUS button click ──
            $(document).on('click', '.plus', function () {
                const container = $(this).closest('.cart-controls');
                const title     = container.data('title');
                const avail     = Number(container.data('available'));

                if (!cart[title]) cart[title] = 0;

                if (cart[title] >= avail) {
                    container.find('.plus').prop('disabled', true);
                    return;
                }

                cart[title]++;
                container.find('.qty').text(cart[title]);
                container.find('.minus').prop('disabled', false);

                if (cart[title] >= avail) {
                    container.find('.plus').prop('disabled', true);
                } else {
                    container.find('.plus').prop('disabled', false);
                }

                var itemDetails = {
                    BookId            : container.data('id'),
                    Title             : container.data('title'),
                    ImageUrl          : container.data('imageurl'),
                    AvailableQuantity : cart[title],
                    Year              : container.data('year'),
                    Username          : "@Context.Session.GetString("UserName")"
                };

                $.ajax({
                    url         : '/CartControllercs/IncreaseQtyByOne',
                    type        : 'POST',
                    data        : JSON.stringify(itemDetails),
                    contentType : 'application/json',
                    success     : function () {
                        updateCartUIFromServer();
                        updateQtyControlsBasedOnRole();
                    }
                });
            });

            // ── MINUS button click ──
            $(document).on('click', '.minus', function () {
                const container = $(this).closest('.cart-controls');
                const title     = container.data('title');

                if (!cart[title] || cart[title] <= 0) return;

                cart[title]--;
                container.find('.qty').text(cart[title]);

                if (cart[title] === 0) {
                    container.find('.qty-controls').addClass('d-none');
                    container.find('.add-btn').removeClass('d-none');
                    delete cart[title];
                }

                const avail  = Number(container.data('available'));
                const qtyNow = Number(container.find('.qty').text()) || 0;

                if (qtyNow < avail) {
                    container.find('.plus').prop('disabled', false);
                }

                var itemDetails = {
                    BookId            : container.data('id'),
                    Title             : container.data('title'),
                    ImageUrl          : container.data('imageurl'),
                    AvailableQuantity : cart[title] || 0,
                    Year              : container.data('year'),
                    Username          : "@Context.Session.GetString("UserName")"
                };

                $.ajax({
                    url         : '/CartControllercs/DecreaseQtyByOne',
                    type        : 'POST',
                    data        : JSON.stringify(itemDetails),
                    contentType : 'application/json',
                    success     : function () {
                        updateCartUIFromServer();
                        updateQtyControlsBasedOnRole();
                    }
                });
            });

        });
    </script>
}